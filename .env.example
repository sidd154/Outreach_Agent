# Production Database
DATABASE_URL=sqlite+aiosqlite:////data/outreach.db

# Auth
ADMIN_API_KEY_SECRET=generate-a-secure-secret-here

# Resend Global Fallback (Optional)
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=hi@pixelsoft.in

# Encryption (Run: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# OpenAI Core (if global fallback desired)
OPENAI_API_KEY=

# App
ENVIRONMENT=production
CORS_ORIGINS=["https://your-vercel-domain.vercel.app"]
